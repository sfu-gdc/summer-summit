{
	"name": "summer-summit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node ./tools/clean-build.ts",
		"build": "node -e \"if (process.env.WRANGLER_COMMAND !== 'types'){process.exit(1)} \" || vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm run gen || echo ''",
		"precheck:wrangler": "pnpm run /^gen:wrangler$/",
		"precheck:svelte": "pnpm run /^gen:svelte-kit$/",
		"check:app": "svelte-check --tsconfig ./tsconfig.app.json",
		"check:tools": "svelte-check --tsconfig ./tsconfig.tools.json",
		"check": "pnpm run /^check:.*/",
		"watch:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.app.json --watch",
		"lint:prettier": "prettier --check .",
		"lint:eslint": "eslint --max-warnings=0 .",
		"lint": "pnpm run /^lint:.*/",
		"format": "prettier --write .",
		"test": "vitest",
		"gen:wrangler": "wrangler types ./@types/worker-configuration.d.ts",
		"gen:svelte-kit": "svelte-kit sync",
		"gen": "pnpm run /^gen:.*/",
		"storybook": "storybook dev --no-open -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@fontsource-variable/work-sans": "^5.2.8",
		"@fontsource/syncopate": "^5.2.8",
		"@unocss/preset-wind4": "^66.7.5",
		"@unocss/reset": "^66.7.5",
		"bits-ui": "^2.18.1",
		"culori": "^4.0.2"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@eslint/js": "^10.0.1",
		"@iconify-json/mdi": "^1.2.3",
		"@storybook/addon-a11y": "^10.5.0",
		"@storybook/addon-docs": "^10.5.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.5.0",
		"@storybook/sveltekit": "^10.5.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/culori": "^4.0.1",
		"@types/node": "^24.13.3",
		"@unocss/eslint-config": "^66.7.5",
		"@unocss/extractor-svelte": "^66.7.5",
		"@unocss/preset-web-fonts": "^66.7.5",
		"@unocss/svelte-scoped": "^66.7.5",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"chromatic": "^18.0.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.10.0",
		"eslint-plugin-storybook": "^10.5.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"storybook": "^10.5.0",
		"storybook-addon-pseudo-states": "^10.5.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"type-fest": "^5.8.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"unocss": "^66.7.5",
		"unplugin-fonts": "^2.0.0",
		"vite": "^8.1.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0",
		"wrangler": "^4.110.0"
	},
	"packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.18.0",
			"onFail": "download"
		}
	}
}
