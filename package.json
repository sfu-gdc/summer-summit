{
	"name": "summer-summit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node ./tools/clean-build.ts",
		"build": "node -e \"if (process.env.WRANGLER_COMMAND !== 'types'){process.exit(1)} \" || vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm run gen || echo ''",
		"precheck:wrangler": "pnpm run /^gen:wrangler$/",
		"check:wrangler": "wrangler types ./@types/worker-configuration.d.ts --check",
		"precheck:svelte": "pnpm run /^gen:svelte-kit$/",
		"check:svelte": "svelte-check --tsconfig ./tsconfig.app.json",
		"check": "pnpm run /^check:.*/",
		"watch:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.app.json --watch",
		"lint:prettier": "prettier --check .",
		"lint:eslint": "eslint .",
		"lint": "pnpm run /^lint:.*/",
		"format": "prettier --write .",
		"test": "vitest",
		"gen:wrangler": "wrangler types ./@types/worker-configuration.d.ts",
		"gen:svelte-kit": "svelte-kit sync",
		"gen": "pnpm run /^gen:.*/",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@fontsource-variable/work-sans": "^5.2.8",
		"@fontsource/syncopate": "^5.2.8",
		"@unocss/reset": "^66.7.2",
		"bits-ui": "^2.18.1"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/sveltekit": "^10.4.6",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"@unocss/eslint-config": "^66.7.2",
		"@unocss/extractor-svelte": "^66.7.2",
		"@unocss/preset-web-fonts": "^66.7.2",
		"@unocss/svelte-scoped": "^66.7.2",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"chromatic": "^17.6.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.6",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"storybook": "^10.4.6",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"type-fest": "^5.7.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"unocss": "^66.7.2",
		"unplugin-fonts": "^2.0.0",
		"vite": "^8.1.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.104.0"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.18.0",
			"onFail": "download"
		}
	}
}
